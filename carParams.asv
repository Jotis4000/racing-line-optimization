%%% SET CAR PARAMETERS

function par = carParams()

    % Simple Params
    par.Vmax = 320/3.6; % m/s
    par.m = 798; % kg
    
    % Second Order Params - Required for more advanced model
    par.CLA = 4.5;
    par.CDA = 1
    par.rho = 1.225;
    par.accelmax = 1.5; % g
    par.decelmax = 5; % g
    par.latmax = 5; % g

end